<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Web Automation Suite">
    <test name="Smoke Tests" preserve-order="true">
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.HRMSTest"/>
            <class name="tests.SearchEmployeeTest">
                <methods>
                    <!-- Read-only first, then edits, deactivate LAST -->
                    <include name="searchAndVerifyEmployee"/>
                    <include name="editEmployee"/>
                    <include name="editCampaignAssignment"/>
                    <include name="deactivateEmployee"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>
